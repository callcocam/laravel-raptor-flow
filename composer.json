{
    "name": "callcocam/laravel-raptor-flow",
    "description": "This is my package laravel-raptor-flow",
    "keywords": [
        "Claudio Campos",
        "laravel",
        "laravel-raptor-flow"
    ],
    "homepage": "https://github.com/callcocam/laravel-raptor-flow",
    "license": "MIT",
    "authors": [
        {
            "name": "Claudio Campos",
            "email": "contato@sigasmar.com.br",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "nunomaduro/collision": "^8.6",
        "orchestra/testbench": "^9.0.0||^8.22.0",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-arch": "^2.7",
        "pestphp/pest-plugin-laravel": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Callcocam\\LaravelRaptorFlow\\": "src/",
            "Callcocam\\LaravelRaptorFlow\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Callcocam\\LaravelRaptorFlow\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-laravel-raptor-flow --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Callcocam\\LaravelRaptorFlow\\LaravelRaptorFlowServiceProvider"
            ],
            "aliases": {
                "LaravelRaptorFlow": "Callcocam\\LaravelRaptorFlow\\Facades\\LaravelRaptorFlow"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "./packages/callcocam/laravel-raptor"
        },
        {
            "type": "path",
            "url": "./packages/callcocam/laravel-raptor-flow"
        }
    ]
}